rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allChildren=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Publicly shareable routines: anyone can read a shared routine by its id,
    // any signed-in user can publish one. No updates/deletes (shares are immutable).
    match /shared_routines/{shareId} {
      allow read: if true;
      allow create: if request.auth != null;
    }
  }
}
